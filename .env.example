# =============================================
# PhishAware – Beispiel-Konfiguration
# Kopieren nach ".env" und mit echten Werten fuellen.
# ".env" NIEMALS committen (siehe .gitignore).
# =============================================

# === App ===
APP_DOMAIN=phishaware.example.com
ENVIRONMENT=production
LOG_LEVEL=INFO

# === Database ===
POSTGRES_DB=phishaware
POSTGRES_USER=phishaware
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql://phishaware:change-me-strong-password@postgres:5432/phishaware

# === Redis ===
REDIS_URL=redis://redis:6379

# === Security ===
# Generieren: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-min-32-characters-random

# === OIDC (beliebiger Provider: Authentik, Keycloak, Entra ID, Okta, ...) ===
OIDC_ISSUER=https://idp.example.com/application/o/phishaware/
OIDC_CLIENT_ID=phishaware
OIDC_CLIENT_SECRET=change-me
OIDC_REDIRECT_URI=https://phishaware.example.com/auth/callback

# === SMTP (beliebiger Anbieter – siehe smtp-konfiguration.md) ===
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=noreply@example.com
SMTP_PASSWORD=change-me
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=PhishAware Training
SMTP_USE_TLS=true
SMTP_VERIFY_SSL=true
SMTP_BATCH_DELAY=2

# === Frontend ===
VITE_API_URL=http://localhost:8000

# === CORS (kommagetrennte Liste erlaubter Origins) ===
CORS_ORIGINS=http://localhost:5173
