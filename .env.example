# =============================================
# HumanShield.APP – Beispiel-Konfiguration
# Kopieren nach ".env" und mit echten Werten fuellen.
# ".env" NIEMALS committen (siehe .gitignore).
# =============================================

# === App ===
APP_DOMAIN=humanshield.example.com
# Worauf Caddy hoert (Default: localhost). Moegliche Werte:
#   - Echte Domain (z. B. "humanshield.example.com") -> automatisches Let's Encrypt.
#   - ":80" -> Catch-all, reines HTTP, matcht jeden Host. Sinnvoll, wenn ein
#     vorgelagerter Reverse Proxy (Netbird, Cloudflare, ...) TLS zum Client
#     terminiert und uns per HTTP mit Host=IP anspricht. TLS_DIRECTIVE leer lassen.
# CADDY_SITE_ADDRESS=humanshield.example.com
#
# Nur bei einer Domain als CADDY_SITE_ADDRESS relevant: erzwingt Caddys interne
# CA (selbstsigniert) statt eines echten Let's-Encrypt-Zertifikats - fuer Domains,
# die oeffentlich nicht per HTTP-01/TLS-ALPN-01 erreichbar sind (z. B. VPN-only).
# Fuer echte, oeffentlich erreichbare Domains leer lassen/entfernen.
# TLS_DIRECTIVE=tls internal
ENVIRONMENT=production
LOG_LEVEL=INFO

# === Database ===
POSTGRES_DB=phishaware
POSTGRES_USER=phishaware
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql+psycopg://phishaware:change-me-strong-password@postgres:5432/phishaware

# === Redis ===
REDIS_URL=redis://redis:6379

# === Security ===
# Generieren: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-min-32-characters-random

# === Lokaler Login (primaere Anmeldemethode) ===
# Nur beim allerersten Start wirksam, solange noch kein User mit dieser E-Mail existiert.
# Danach weitere lokale Konten ueber POST /users (admin-only) anlegen.
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change-me

# === OIDC / SSO (optionale Zweitmethode) ===
# Wird NICHT mehr ueber .env konfiguriert, sondern im Dashboard unter
# Einstellungen -> OIDC / Single Sign-On (Issuer, Client-ID, Client-Secret,
# Redirect-URI). Das Client-Secret liegt verschluesselt in der DB.

# === SMTP (beliebiger Anbieter – siehe smtp-konfiguration.md) ===
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=noreply@example.com
SMTP_PASSWORD=change-me
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=HumanShield-Awareness
SMTP_TLS_MODE=starttls
SMTP_VERIFY_SSL=true
SMTP_BATCH_DELAY=2

# === Lizenzierung / Add-ons (optional) ===
# Leer lassen = reiner Open-Core-Betrieb ohne kostenpflichtige Add-ons.
# LICENSE_SERVER_URL: Endpunkt des Anbieters, der signierte Leases ausstellt.
# LICENSE_KEY: der gekaufte Lizenzschluessel (kann alternativ im Dashboard gepflegt werden).
LICENSE_SERVER_URL=
LICENSE_KEY=
LICENSE_REFRESH_INTERVAL_HOURS=24

# === Frontend ===
# Relativ zum selben Origin (empfohlen): der Browser ruft /api auf, Caddy leitet
# an das Backend weiter - funktioniert unabhaengig vom Zugriffsweg (localhost,
# VPN, echte Domain), ohne Mixed-Content/CORS. Nur fuer den direkten Zugriff auf
# den Vite-Devserver (Port 5173 ohne Caddy davor) waere http://localhost:8000 noetig.
VITE_API_URL=/api
# Optional: Dashboard-Port nur an eine bestimmte Netzwerkschnittstelle binden
# (z. B. ein VPN-/Overlay-Interface), statt an alle Interfaces (0.0.0.0).
# Praktisch fuer eine Testphase, bevor der Zugriff oeffentlich freigegeben wird.
# FRONTEND_BIND_ADDRESS=203.0.113.10

# === CORS (kommagetrennte Liste erlaubter Origins) ===
CORS_ORIGINS=http://localhost:5173
