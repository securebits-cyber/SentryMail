# =============================================
# HumanShield.APP – Beispiel-Konfiguration / Example configuration
# DE: Kopieren nach ".env" und mit echten Werten fuellen. ".env" NIEMALS committen (siehe .gitignore).
# EN: Copy to ".env" and fill in real values. NEVER commit ".env" (see .gitignore).
# =============================================

# === App ===
APP_DOMAIN=humanshield.example.com
# DE: Worauf Caddy hoert (Default: localhost). Moegliche Werte:
#   - Echte Domain (z. B. "humanshield.example.com") -> automatisches Let's Encrypt.
#   - ":80" -> Catch-all, reines HTTP, matcht jeden Host. Sinnvoll, wenn ein vorgelagerter
#     Reverse Proxy (Netbird, Cloudflare, ...) TLS zum Client terminiert und uns per HTTP
#     mit Host=IP anspricht. TLS_DIRECTIVE leer lassen.
# EN: What Caddy listens on (default: localhost). Possible values:
#   - A real domain (e.g. "humanshield.example.com") -> automatic Let's Encrypt.
#   - ":80" -> catch-all, plain HTTP, matches any host. Useful when an upstream reverse
#     proxy (Netbird, Cloudflare, ...) terminates TLS to the client and reaches us over
#     HTTP with Host=IP. Leave TLS_DIRECTIVE empty.
# CADDY_SITE_ADDRESS=humanshield.example.com
#
# DE: Nur bei einer Domain als CADDY_SITE_ADDRESS relevant: erzwingt Caddys interne CA
#     (selbstsigniert) statt eines echten Let's-Encrypt-Zertifikats - fuer Domains, die
#     oeffentlich nicht per HTTP-01/TLS-ALPN-01 erreichbar sind (z. B. VPN-only). Fuer echte,
#     oeffentlich erreichbare Domains leer lassen/entfernen.
# EN: Only relevant with a domain as CADDY_SITE_ADDRESS: forces Caddy's internal CA
#     (self-signed) instead of a real Let's Encrypt certificate - for domains not publicly
#     reachable via HTTP-01/TLS-ALPN-01 (e.g. VPN-only). For real, publicly reachable
#     domains leave empty/remove.
# TLS_DIRECTIVE=tls internal
ENVIRONMENT=production
LOG_LEVEL=INFO

# === Database ===
POSTGRES_DB=phishaware
POSTGRES_USER=phishaware
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql+psycopg://phishaware:change-me-strong-password@postgres:5432/phishaware

# === Redis ===
REDIS_URL=redis://redis:6379

# === Security ===
# DE: Generieren: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# EN: Generate:   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-min-32-characters-random

# === Lokaler Login / Local login (primaere Anmeldemethode / primary sign-in method) ===
# DE: Nur beim allerersten Start wirksam, solange noch kein User mit dieser E-Mail existiert.
#     Danach weitere lokale Konten ueber POST /users (admin-only) anlegen.
# EN: Only effective on the very first start, as long as no user with this email exists yet.
#     Afterwards create further local accounts via POST /users (admin-only).
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change-me

# === OIDC / SSO (optionale Zweitmethode / optional second method) ===
# DE: Wird NICHT mehr ueber .env konfiguriert, sondern im Dashboard unter
#     Einstellungen -> OIDC / Single Sign-On (Issuer, Client-ID, Client-Secret,
#     Redirect-URI). Das Client-Secret liegt verschluesselt in der DB.
# EN: No longer configured via .env, but in the dashboard under
#     Settings -> OIDC / Single Sign-On (issuer, client ID, client secret,
#     redirect URI). The client secret is stored encrypted in the DB.

# === SMTP (beliebiger Anbieter / any provider – siehe/see smtp-konfiguration.md) ===
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=noreply@example.com
SMTP_PASSWORD=change-me
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=HumanShield-Awareness
SMTP_TLS_MODE=starttls
SMTP_VERIFY_SSL=true
SMTP_BATCH_DELAY=2

# === Passkeys / WebAuthn (Business, optional) ===
# DE: Die RP-ID leitet sich aus APP_DOMAIN ab. Die erwartete Browser-Origin ist
#     standardmaessig https://{APP_DOMAIN}; nur fuer abweichende Setups (z. B. lokale
#     Entwicklung ueber http://localhost:5173) hier ueberschreiben.
# EN: The RP ID is derived from APP_DOMAIN. The expected browser origin defaults to
#     https://{APP_DOMAIN}; override here only for diverging setups (e.g. local
#     development via http://localhost:5173).
# WEBAUTHN_ORIGIN=https://awareness.example.com

# === GeoIP (optional) ===
# DE: Pfad zu einer lokalen Country-Datenbank im MMDB-Format fuer die Laender-Statistik
#     (z. B. GeoLite2-Country.mmdb, dbip-country-lite.mmdb). Leer lassen = kein
#     Laender-Lookup; es wird nie ein externer Dienst aufgerufen.
# EN: Path to a local country database in MMDB format for the country statistics
#     (e.g. GeoLite2-Country.mmdb, dbip-country-lite.mmdb). Empty = no country
#     lookup; no external service is ever called.
GEOIP_DB_PATH=

# === Session-Cookie ===
# DE: Die Browser-Session laeuft ueber ein httpOnly-Cookie (+ CSRF-Double-Submit).
#     COOKIE_SECURE=true sendet das Cookie nur ueber HTTPS (empfohlen, Standard).
#     Nur fuer lokale Entwicklung ohne TLS (http://localhost) auf false setzen.
# EN: The browser session runs over an httpOnly cookie (+ CSRF double-submit).
#     COOKIE_SECURE=true sends the cookie only over HTTPS (recommended, default).
#     Set to false only for local development without TLS (http://localhost).
COOKIE_SECURE=true

# === Update-Check / Update check (optional) ===
# DE: Prueft, ob ein neueres Release verfuegbar ist, und zeigt im Dashboard einen Hinweis
#     "Update verfuegbar" mit Changelog-Link. Erwartet eine URL im Format der GitHub-
#     Releases-API (JSON mit "tag_name"). Default zeigt auf das Projekt-Repo. UPDATE_CHECK_URL
#     leeren = Update-Check komplett aus (Air-Gapped/White-Label). Hinweis: Bei einem privaten
#     Repo liefert die oeffentliche GitHub-API 404 - dann eine erreichbare/eigene Quelle
#     setzen oder den Check deaktivieren.
# EN: Checks whether a newer release is available and shows an "update available" hint with a
#     changelog link in the dashboard. Expects a URL in the format of the GitHub releases API
#     (JSON with "tag_name"). Default points to the project repo. Empty UPDATE_CHECK_URL =
#     update check fully off (air-gapped/white-label). Note: for a private repo the public
#     GitHub API returns 404 - then set a reachable/own source or disable the check.
UPDATE_CHECK_URL=https://api.github.com/repos/HumanShield-Awareness/HumanShield.APP/releases/latest
UPDATE_CHANGELOG_URL=https://github.com/HumanShield-Awareness/HumanShield.APP/releases
UPDATE_CHECK_INTERVAL_HOURS=6
UPDATE_CHECK_TIMEOUT=4

# === Lizenzierung / Licensing – Add-ons (optional) ===
# DE: Leer lassen = reiner Open-Core-Betrieb ohne kostenpflichtige Add-ons.
#     LICENSE_SERVER_URL: Endpunkt des Anbieters, der signierte Leases ausstellt.
#     LICENSE_KEY: der gekaufte Lizenzschluessel (kann alternativ im Dashboard gepflegt werden).
# EN: Empty = pure Open Core operation without paid add-ons.
#     LICENSE_SERVER_URL: endpoint of the provider that issues signed leases.
#     LICENSE_KEY: the purchased license key (can alternatively be managed in the dashboard).
LICENSE_SERVER_URL=
LICENSE_KEY=
LICENSE_REFRESH_INTERVAL_HOURS=24

# === Frontend ===
# DE: Relativ zum selben Origin (empfohlen): der Browser ruft /api auf, Caddy leitet an das
#     Backend weiter - funktioniert unabhaengig vom Zugriffsweg (localhost, VPN, echte Domain),
#     ohne Mixed-Content/CORS. Nur fuer den direkten Zugriff auf den Vite-Devserver (Port 5173
#     ohne Caddy davor) waere http://localhost:8000 noetig.
# EN: Relative to the same origin (recommended): the browser calls /api, Caddy forwards to the
#     backend - works regardless of the access path (localhost, VPN, real domain), without
#     mixed content/CORS. Only for direct access to the Vite dev server (port 5173 without
#     Caddy in front) would http://localhost:8000 be needed.
VITE_API_URL=/api
# DE: Ziel des "Wiki / Doku"-Buttons in der Seitenleiste. Leer lassen = Projekt-Wiki auf GitHub;
#     fuer ein eigenes (self-hosted) Wiki hier die eigene URL eintragen.
# EN: Target of the "Wiki / Docs" button in the sidebar. Empty = project wiki on GitHub;
#     for your own (self-hosted) wiki enter your URL here.
# VITE_WIKI_URL=https://wiki.example.com
# DE: Optional: Dashboard-Port nur an eine bestimmte Netzwerkschnittstelle binden (z. B. ein
#     VPN-/Overlay-Interface), statt an alle Interfaces (0.0.0.0). Praktisch fuer eine Testphase,
#     bevor der Zugriff oeffentlich freigegeben wird.
# EN: Optional: bind the dashboard port only to a specific network interface (e.g. a VPN/overlay
#     interface) instead of all interfaces (0.0.0.0). Handy for a test phase before access is
#     opened publicly.
# FRONTEND_BIND_ADDRESS=203.0.113.10

# === CORS (kommagetrennte Liste erlaubter Origins / comma-separated list of allowed origins) ===
CORS_ORIGINS=http://localhost:5173

# === LMS-Video-Storage (Enterprise Add-on) / LMS video storage (Enterprise add-on) ===
# DE: Speicher-Backend fuer Schulungsvideos: "filesystem" (Dateien im Datenverzeichnis,
#     Default) oder "s3" (S3-kompatibler Object Storage, z. B. selbstgehostetes MinIO).
#     Videos bleiben immer vollstaendig in der eigenen Installation (kein Drittanbieter-CDN).
# EN: Storage backend for training videos: "filesystem" (files in the data directory,
#     default) or "s3" (S3-compatible object storage, e.g. self-hosted MinIO).
#     Videos always stay entirely within your own installation (no third-party CDN).
# LMS_STORAGE_BACKEND=filesystem
# LMS_MEDIA_DIR=data/lms_media
# DE: Nur bei LMS_STORAGE_BACKEND=s3 noetig (beliebiger S3-kompatibler Anbieter).
# EN: Only needed with LMS_STORAGE_BACKEND=s3 (any S3-compatible provider).
# LMS_S3_ENDPOINT_URL=https://s3.example.com
# LMS_S3_BUCKET=lms-videos
# LMS_S3_ACCESS_KEY=changeme
# LMS_S3_SECRET_KEY=changeme
# LMS_S3_REGION=
