# =============================================
# HumanShield.APP Frontend – Beispiel-Konfiguration / Example configuration
# DE: Nur relevant fuer lokale Entwicklung ausserhalb von Docker Compose
#     (docker-compose.yml setzt VITE_API_URL bereits ueber die Root-.env).
#     Kopieren nach "frontend/.env" - niemals mit echten Werten committen.
# EN: Only relevant for local development outside of Docker Compose
#     (docker-compose.yml already sets VITE_API_URL via the root .env).
#     Copy to "frontend/.env" - never commit with real values.
# =============================================

VITE_API_URL=http://localhost:8000

# DE: Ziel des "Wiki / Doku"-Buttons in der Seitenleiste. Leer lassen, um das Projekt-Wiki
#     auf GitHub zu verwenden; fuer ein eigenes (self-hosted) Wiki hier die eigene URL eintragen.
# EN: Target of the "Wiki / Docs" button in the sidebar. Leave empty to use the project wiki
#     on GitHub; for your own (self-hosted) wiki enter your URL here.
# VITE_WIKI_URL=https://wiki.example.com
