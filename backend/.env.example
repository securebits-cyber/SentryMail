# =============================================
# PhishAware Backend – Beispiel-Konfiguration
# Nur fuer Standalone-Betrieb des Backends ausserhalb von Docker Compose
# (z. B. lokales `uvicorn app.main:app --reload` im backend/-Ordner).
# Im Docker-Compose-Stack kommt die Konfiguration aus der .env im Repo-Root.
#
# Kopieren nach "backend/.env" und mit echten Werten fuellen.
# "backend/.env" NIEMALS committen (siehe .gitignore, chmod 600).
# =============================================

# === App ===
APP_DOMAIN=localhost
ENVIRONMENT=development
LOG_LEVEL=DEBUG
CORS_ORIGINS=http://localhost:5173

# === Database ===
DATABASE_URL=postgresql://phishaware:change-me@localhost:5432/phishaware

# === Redis ===
REDIS_URL=redis://localhost:6379

# === Security ===
# Generieren: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-min-32-characters-random
ACCESS_TOKEN_EXPIRE_MINUTES=30

# === OIDC (beliebiger Provider: Authentik, Keycloak, Entra ID, Okta, ...) ===
OIDC_ISSUER=https://idp.example.com/application/o/phishaware/
OIDC_CLIENT_ID=phishaware
OIDC_CLIENT_SECRET=change-me
OIDC_REDIRECT_URI=http://localhost:8000/auth/callback

# === SMTP (beliebiger Anbieter - siehe docs/Phishing awareness smtp konfiguration.md) ===
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=noreply@example.com
SMTP_PASSWORD=change-me
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=PhishAware Training
SMTP_USE_TLS=true
SMTP_VERIFY_SSL=true
SMTP_BATCH_DELAY=2
