# =============================================
# HumanShield.APP Backend – Beispiel-Konfiguration / Example configuration
# DE: Nur fuer Standalone-Betrieb des Backends ausserhalb von Docker Compose
#     (z. B. lokales `uvicorn app.main:app --reload` im backend/-Ordner).
#     Im Docker-Compose-Stack kommt die Konfiguration aus der .env im Repo-Root.
#     Kopieren nach "backend/.env" und mit echten Werten fuellen.
#     "backend/.env" NIEMALS committen (siehe .gitignore, chmod 600).
# EN: Only for running the backend standalone outside of Docker Compose
#     (e.g. local `uvicorn app.main:app --reload` in the backend/ folder).
#     In the Docker Compose stack the configuration comes from the .env in the repo root.
#     Copy to "backend/.env" and fill in real values.
#     NEVER commit "backend/.env" (see .gitignore, chmod 600).
# =============================================

# === App ===
APP_DOMAIN=localhost
ENVIRONMENT=development
LOG_LEVEL=DEBUG
CORS_ORIGINS=http://localhost:5173

# === Database ===
DATABASE_URL=postgresql+psycopg://phishaware:change-me@localhost:5432/phishaware

# === Redis ===
REDIS_URL=redis://localhost:6379

# === Security ===
# DE: Generieren: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# EN: Generate:   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-min-32-characters-random
ACCESS_TOKEN_EXPIRE_MINUTES=30

# === Lokaler Login / Local login (primaere Anmeldemethode / primary sign-in method) ===
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change-me

# === OIDC (optional, Zweitmethode / second method - beliebiger Provider / any provider: Authentik, Keycloak, Entra ID, Okta, ...) ===
# DE: Leer lassen/entfernen, um OIDC/SSO komplett zu deaktivieren.
# EN: Leave empty/remove to disable OIDC/SSO entirely.
OIDC_ISSUER=https://idp.example.com/application/o/humanshield/
OIDC_CLIENT_ID=humanshield
OIDC_CLIENT_SECRET=change-me
OIDC_REDIRECT_URI=http://localhost:8000/auth/callback

# === SMTP (beliebiger Anbieter / any provider - siehe/see docs/Phishing awareness smtp konfiguration.md) ===
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=noreply@example.com
SMTP_PASSWORD=change-me
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=HumanShield-Awareness
SMTP_TLS_MODE=starttls
SMTP_VERIFY_SSL=true
SMTP_BATCH_DELAY=2
